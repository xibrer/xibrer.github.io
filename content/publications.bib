@inproceedings{wang2026largecall,
  selected={true},
  title = {LargeCall: Dual-Modality Speech Enhancement for Noise-Robust Phone Calls Using Smartphone's Built-in Accelerometer},
  author = {Lei Wang and Xingwei Wang and Yu Zhang and Xiaolei Ma and Yong Zhang and Zhijun Li and Tao Gu},
  year = {2026},
  booktitle = {IEEE International Conference on Computer Communications (INFOCOM)},
  preview = {large.png},
  abstract = {This paper presents LargeCall, a dual-modality speech enhancement system that leverages smartphone's built-in accelerometer and microphone to improve phone call quality in noisy environments. Using large audio model-based speech priors, LargeCall achieves robust noise suppression.},
